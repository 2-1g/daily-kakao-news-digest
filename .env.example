# Secrets are injected at runtime; never commit real values.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLOUD_PROJECT=
KAKAO_TOKEN_SECRET=kakao-token
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
ENABLE_GDELT=false
NEWS_DIGEST_LIVE_SEND=false
# Optional: read a precomposed JSON string list instead of collecting sources.
NEWS_DIGEST_MESSAGES_FILE=
# The registry is fail-closed; its entries must be reviewed before approval.
SOURCE_REGISTRY=config/sources.yaml
