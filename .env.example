# Secrets are injected at runtime; never commit real values.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLOUD_PROJECT=
KAKAO_TOKEN_SECRET=kakao-token
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
ENABLE_GDELT=false
NEWS_DIGEST_LIVE_SEND=false
# Optional: read a precomposed JSON string list instead of collecting sources.
NEWS_DIGEST_MESSAGES_FILE=
# The registry is fail-closed; its entries must be reviewed before approval.
SOURCE_REGISTRY=config/sources.yaml
MODEL_SUMMARIZER_ENABLED=false
MODEL_API_KEY=
MODEL_NANO_NAME=
MODEL_MINI_NAME=
MODEL_PRICING_JSON={}
MODEL_MAX_RUN_USD=0.10
MODEL_MAX_REQUEST_USD=0.03
MODEL_MAX_OUTPUT_TOKENS=500
NEWS_DIGEST_OPERATOR=
NEWS_DIGEST_MONTHLY_BUDGET_USD=5
